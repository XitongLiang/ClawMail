{
  "skill_name": "clawmail-personalization",
  "version": "1.0.0",
  "description": "基于用户反馈自动优化 ClawMail 邮件重要性评分标准",
  
  "trigger": {
    "agent": "clawmail-monitor",
    "condition": "feedback_count >= 5",
    "signal_format": {
      "signal": "trigger_personalization",
      "source": "clawmail-monitor",
      "target": "clawmail-personalization",
      "data": {
        "feedback_file": "~/clawmail_data/feedback/feedback_importance_score.jsonl",
        "feedback_count": 5,
        "target_prompt": "importance_score",
        "timestamp": "2026-02-27T10:00:00"
      }
    }
  },
  
  "paths": {
    "feedback_file": "~/clawmail_data/feedback/feedback_importance_score.jsonl",
    "prompt_file": "~/clawmail_data/prompts/importance_score.txt",
    "data_dir": "~/clawmail_data",
    "feedback_archive_dir": "~/clawmail_data/feedback/importance_score",
    "prompt_archive_dir": "~/clawmail_data/prompts/archive"
  },
  
  "settings": {
    "feedback_threshold": 5,
    "archive_enabled": true,
    "update_memory": true,
    "backup_prompt": true
  },
  
  "personalization": {
    "supported_prompts": [
      "importance_score",
      "category",
      "urgency"
    ],
    "adjustment_range": {
      "min": -25,
      "max": 25,
      "typical": {
        "min": -15,
        "max": 15
      }
    }
  },
  
  "logging": {
    "level": "info",
    "stdout": true,
    "file": null
  }
}
